<!DOCTYPE html>

<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
<meta name="theme-color" content="#0a0a0c">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>GeoDuell</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  /* Surfaces — layered depth */
  --bg-0: hsl(225, 15%, 5%);
  --bg-1: hsl(225, 14%, 7%);
  --bg-2: hsl(225, 13%, 10%);
  --surface-1: hsla(225, 20%, 100%, 0.04);
  --surface-2: hsla(225, 20%, 100%, 0.07);
  --surface-3: hsla(225, 20%, 100%, 0.1);
  --hairline: hsla(225, 15%, 100%, 0.08);
  --hairline-strong: hsla(225, 15%, 100%, 0.16);

/* Text */
–fg: hsl(225, 20%, 98%);
–fg-muted: hsl(225, 14%, 75%);
–fg-dim: hsl(225, 12%, 58%);
–fg-faint: hsl(225, 10%, 42%);

/* Brand accent */
–accent: hsl(180, 90%, 55%);
–accent-soft: hsla(180, 90%, 55%, 0.15);
–accent-glow: hsla(180, 90%, 55%, 0.4);

/* Semantics */
–good: hsl(150, 70%, 60%);
–warn: hsl(38, 100%, 65%);
–bad: hsl(348, 95%, 65%);

/* Map */
–water: hsl(220, 50%, 7%);
–water-deep: hsl(220, 60%, 5%);
–land: hsl(180, 12%, 14%);
–land-stroke: hsla(180, 25%, 50%, 0.25);

/* Motion */
–ease-out: cubic-bezier(0.22, 1, 0.36, 1);
–ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
–ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

/* Layout */
–sa-top: env(safe-area-inset-top, 0px);
–sa-bot: env(safe-area-inset-bottom, 0px);
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
html { background: #0a0a0c; color-scheme: dark; }
html, body { overscroll-behavior: none; -webkit-user-select: none; user-select: none; background-color: #0a0a0c; }
input, textarea { -webkit-user-select: text; user-select: text; }

body {
background-color: #0a0a0c !important;
background-image: radial-gradient(1200px 800px at 80% -10%, rgba(0, 200, 220, 0.05), transparent 60%),
radial-gradient(900px 600px at 0% 100%, rgba(180, 100, 255, 0.04), transparent 55%);
color: var(–fg);
font-family: ‘Inter’, -apple-system, BlinkMacSystemFont, sans-serif;
height: 100dvh;
overflow: hidden;
display: flex;
flex-direction: column;
font-size: 15px;
font-feature-settings: ‘cv11’, ‘ss01’, ‘ss03’;
-webkit-font-smoothing: antialiased;
-moz-osx-font-smoothing: grayscale;
letter-spacing: -0.01em;
}

/* ── HEADER ─────────────────────────────────────────────────────────────── */
.header {
display: flex;
align-items: center;
justify-content: space-between;
padding: calc(var(–sa-top) + 12px) 18px 12px;
background: linear-gradient(180deg, rgba(10,10,12,0.85), rgba(10,10,12,0.4) 80%, transparent);
backdrop-filter: blur(12px) saturate(140%);
-webkit-backdrop-filter: blur(12px) saturate(140%);
flex-shrink: 0;
position: relative;
z-index: 100;
}
.logo {
font-family: ‘Inter Tight’, sans-serif;
font-size: 1.15rem;
font-weight: 800;
letter-spacing: -0.04em;
line-height: 1;
display: flex;
align-items: center;
gap: 8px;
}
.logo-dot {
width: 8px; height: 8px; border-radius: 50%;
background: var(–accent);
box-shadow: 0 0 12px var(–accent-glow), 0 0 0 4px hsla(180, 90%, 55%, 0.1);
animation: pulse 2.4s ease-in-out infinite;
}
@keyframes pulse {
0%, 100% { transform: scale(1); opacity: 1; }
50% { transform: scale(1.4); opacity: 0.6; }
}
.header-meta {
display: flex;
align-items: center;
gap: 8px;
font-size: 0.75rem;
color: var(–fg-muted);
}
.chip {
display: inline-flex;
align-items: center;
gap: 6px;
padding: 5px 10px;
border-radius: 100px;
background: var(–surface-1);
border: 1px solid var(–hairline);
font-size: 0.7rem;
font-weight: 500;
color: var(–fg-muted);
letter-spacing: 0;
}
.chip.live { color: var(–accent); border-color: var(–accent-soft); background: var(–accent-soft); }
.chip strong { color: var(–fg); font-weight: 600; }

/* ── SCREENS ───────────────────────────────────────────────────────────── */
.screen {
display: none;
flex: 1;
overflow: hidden;
flex-direction: column;
}
.screen.active { display: flex; animation: screenIn 0.35s var(–ease-out); }
@keyframes screenIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

.screen { background-color: #0a0a0c; }
.screen.scroll { overflow-y: auto; padding-bottom: var(–sa-bot); background-color: #0a0a0c; }
.screen.padded { padding: 8px 18px calc(18px + var(–sa-bot)); background-color: #0a0a0c; }
.screen.center { align-items: center; justify-content: center; background-color: #0a0a0c; }
#screen-guess, #screen-result { background-color: transparent; }

.container { width: 100%; max-width: 460px; margin: 0 auto; }
.stack { display: flex; flex-direction: column; }
.stack-sm > * + * { margin-top: 8px; }
.stack-md > * + * { margin-top: 14px; }
.stack-lg > * + * { margin-top: 22px; }

/* ── TYPOGRAPHY ────────────────────────────────────────────────────────── */
.eyebrow {
font-size: 0.68rem;
text-transform: uppercase;
letter-spacing: 0.18em;
color: var(–fg-dim);
font-weight: 600;
font-family: ‘JetBrains Mono’, monospace;
}
.title {
font-family: ‘Inter Tight’, sans-serif;
font-weight: 800;
letter-spacing: -0.035em;
line-height: 1;
font-size: 2.2rem;
}
.title-lg { font-size: 3rem; }
.title-xl { font-size: 4rem; letter-spacing: -0.045em; }
.subtitle { color: var(–fg-muted); font-size: 0.9rem; line-height: 1.5; }
.label {
font-size: 0.72rem;
font-weight: 600;
color: var(–fg-muted);
letter-spacing: -0.005em;
margin-bottom: 8px;
}
.num {
font-family: ‘Inter Tight’, sans-serif;
font-weight: 800;
letter-spacing: -0.04em;
font-variant-numeric: tabular-nums;
}
.mono { font-family: ‘JetBrains Mono’, monospace; }

/* ── BUTTONS ───────────────────────────────────────────────────────────── */
.btn {
display: inline-flex;
align-items: center;
justify-content: center;
gap: 8px;
padding: 14px 18px;
font-family: inherit;
font-size: 0.95rem;
font-weight: 600;
letter-spacing: -0.01em;
border: 1px solid var(–hairline-strong);
border-radius: 14px;
background: var(–surface-2);
color: var(–fg);
cursor: pointer;
transition: all 0.18s var(–ease-out);
width: 100%;
position: relative;
overflow: hidden;
}
.btn:active:not(:disabled) { transform: scale(0.97); }
.btn:disabled { opacity: 0.35; cursor: not-allowed; }
.btn-primary {
background: var(–fg);
color: var(–bg-0);
border-color: var(–fg);
font-weight: 700;
}
.btn-primary:hover:not(:disabled) { filter: brightness(1.08); }
.btn-accent {
background: linear-gradient(135deg, var(–accent), hsl(170, 80%, 50%));
color: hsl(220, 30%, 8%);
border: none;
font-weight: 700;
box-shadow: 0 4px 20px hsla(180, 80%, 50%, 0.25), inset 0 1px 0 rgba(255,255,255,0.3);
}
.btn-ghost { background: transparent; border-color: var(–hairline); color: var(–fg-muted); }
.btn-ghost:hover:not(:disabled) { color: var(–fg); border-color: var(–hairline-strong); }
.btn-sm { padding: 10px 14px; font-size: 0.85rem; border-radius: 11px; }
.btn-icon { width: 44px; height: 44px; padding: 0; flex-shrink: 0; border-radius: 12px; }
.btn-arrow { display: inline-block; transition: transform 0.2s var(–ease-out); }
.btn:hover .btn-arrow { transform: translateX(3px); }

/* ── INPUTS ────────────────────────────────────────────────────────────── */
.input {
width: 100%;
padding: 14px 16px;
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 14px;
color: var(–fg);
font-family: inherit;
font-size: 1rem;
font-weight: 500;
letter-spacing: -0.01em;
outline: none;
transition: all 0.18s var(–ease-out);
}
.input::placeholder { color: var(–fg-dim); font-weight: 400; }
.input:focus { border-color: var(–accent); background: var(–surface-2); box-shadow: 0 0 0 4px var(–accent-soft); }

/* ── PLAYER SETUP ──────────────────────────────────────────────────────── */
.title-block { text-align: center; margin: 24px 0 32px; }
.title-block .eyebrow { margin-bottom: 12px; }
.title-block .title { margin-bottom: 8px; }

.row { display: flex; align-items: center; gap: 8px; }
.row > .input { flex: 1; }

.player-list { display: flex; flex-direction: column; gap: 8px; }
.player-row {
display: flex;
align-items: center;
gap: 12px;
padding: 12px 14px;
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 14px;
animation: rowIn 0.35s var(–ease-spring);
position: relative;
overflow: hidden;
}
.player-row::before {
content: ‘’;
position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
background: var(–player-color);
border-radius: 0 2px 2px 0;
}
@keyframes rowIn {
from { opacity: 0; transform: translateX(-12px) scale(0.96); }
to { opacity: 1; transform: none; }
}
.avatar {
width: 36px; height: 36px;
border-radius: 50%;
display: grid;
place-items: center;
font-family: ‘Inter Tight’, sans-serif;
font-weight: 700;
font-size: 0.95rem;
color: hsl(220, 30%, 8%);
letter-spacing: -0.02em;
background: var(–player-color);
box-shadow: 0 0 0 2px hsla(0, 0%, 0%, 0.4), 0 0 16px var(–player-color-glow);
flex-shrink: 0;
}
.avatar.sm { width: 26px; height: 26px; font-size: 0.75rem; box-shadow: 0 0 0 1.5px hsla(0, 0%, 0%, 0.3); }
.avatar.lg { width: 56px; height: 56px; font-size: 1.4rem; }
.avatar.xl { width: 88px; height: 88px; font-size: 2.2rem; }

.player-row .name { flex: 1; font-weight: 600; font-size: 1rem; letter-spacing: -0.015em; }
.icon-btn {
background: none; border: none;
color: var(–fg-dim);
width: 32px; height: 32px;
border-radius: 8px;
cursor: pointer;
display: grid; place-items: center;
transition: all 0.15s;
}
.icon-btn:hover { color: var(–bad); background: hsla(348, 95%, 65%, 0.08); }
.icon-btn svg { width: 18px; height: 18px; }

.empty-state {
text-align: center;
padding: 32px 16px;
border: 1px dashed var(–hairline);
border-radius: 14px;
color: var(–fg-dim);
font-size: 0.85rem;
}

/* ── SETTINGS ──────────────────────────────────────────────────────────── */
.setting-group { margin-bottom: 20px; }
.setting-group .label { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.setting-group .label .hint { font-size: 0.7rem; color: var(–fg-dim); font-weight: 400; }

.segment {
display: grid;
grid-template-columns: repeat(var(–cols, 3), 1fr);
gap: 4px;
padding: 4px;
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 14px;
}
.segment-btn {
background: none; border: none;
padding: 10px 8px;
border-radius: 10px;
color: var(–fg-muted);
font-family: inherit;
font-size: 0.85rem;
font-weight: 600;
letter-spacing: -0.01em;
cursor: pointer;
transition: all 0.18s var(–ease-out);
}
.segment-btn.active { background: var(–surface-3); color: var(–fg); box-shadow: 0 1px 0 var(–hairline-strong) inset, 0 -1px 1px hsla(0,0%,0%,0.3); }
.segment-btn .sub { display: block; font-size: 0.65rem; color: var(–fg-dim); font-weight: 500; margin-top: 2px; letter-spacing: 0; }
.segment-btn.active .sub { color: var(–fg-muted); }

/* ── PASS SCREEN ───────────────────────────────────────────────────────── */
.pass-content { text-align: center; padding: 24px; max-width: 360px; }
.pass-icon-wrap {
width: 96px; height: 96px;
margin: 0 auto 28px;
border-radius: 50%;
display: grid; place-items: center;
background: radial-gradient(circle at 30% 30%, var(–player-color), var(–player-color-deep));
box-shadow: 0 0 0 2px hsla(0, 0%, 0%, 0.5), 0 0 60px var(–player-color-glow), inset 0 2px 8px rgba(255,255,255,0.2);
position: relative;
}
.pass-icon-wrap::after {
content: ‘’;
position: absolute; inset: -8px;
border-radius: 50%;
border: 1px solid var(–player-color-glow);
animation: ringPulse 2s ease-out infinite;
}
@keyframes ringPulse {
0% { transform: scale(0.95); opacity: 0.6; }
100% { transform: scale(1.25); opacity: 0; }
}
.pass-icon-wrap .initials {
font-family: ‘Inter Tight’, sans-serif;
font-weight: 800;
font-size: 2.5rem;
color: hsl(220, 30%, 8%);
letter-spacing: -0.04em;
}
.pass-eyebrow { color: var(–fg-muted); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; }
.pass-name { font-family: ‘Inter Tight’, sans-serif; font-size: 2.4rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1; margin-bottom: 16px; }
.pass-action { color: var(–fg-muted); font-size: 1rem; line-height: 1.5; margin-bottom: 8px; }
.pass-action strong { color: var(–fg); font-weight: 600; }
.pass-warn {
display: inline-flex; align-items: center; gap: 8px;
padding: 8px 14px;
background: hsla(38, 100%, 65%, 0.1);
border: 1px solid hsla(38, 100%, 65%, 0.25);
border-radius: 100px;
color: var(–warn);
font-size: 0.75rem;
font-weight: 600;
letter-spacing: -0.005em;
margin-bottom: 28px;
}

/* ── PICK SCREEN ───────────────────────────────────────────────────────── */
.pick-header { text-align: center; margin: 24px 0 28px; }
.pick-header .eyebrow { margin-bottom: 14px; }
.pick-header .pickers-row { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 18px; }
.pick-header .arrow { color: var(–fg-dim); }
.pick-header h2 { font-family: ‘Inter Tight’, sans-serif; font-size: 1.4rem; font-weight: 700; letter-spacing: -0.025em; }
.pick-header h2 strong { color: var(–accent); font-weight: 800; }

.suggest-wrap { position: relative; }
.sbox {
position: absolute; top: calc(100% + 6px); left: 0; right: 0;
background: hsla(225, 14%, 9%, 0.92);
backdrop-filter: blur(20px) saturate(180%);
-webkit-backdrop-filter: blur(20px) saturate(180%);
border: 1px solid var(–hairline);
border-radius: 14px;
max-height: 240px;
overflow-y: auto;
display: none;
z-index: 50;
box-shadow: 0 16px 40px rgba(0,0,0,0.6), 0 1px 0 var(–hairline-strong) inset;
}
.si {
display: flex; align-items: center; justify-content: space-between; gap: 10px;
padding: 11px 14px;
cursor: pointer;
font-size: 0.9rem;
border-bottom: 1px solid var(–hairline);
font-weight: 500;
transition: background 0.1s;
}
.si:last-child { border-bottom: none; }
.si.hi, .si:hover { background: var(–surface-2); color: var(–accent); }
.si-country { font-size: 0.7rem; color: var(–fg-dim); font-family: ‘JetBrains Mono’, monospace; flex-shrink: 0; letter-spacing: 0.05em; }

.helper-row { display: flex; gap: 8px; }
.helper-row .btn { flex: 1; }

.confirm-card {
padding: 18px;
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 16px;
text-align: center;
}
.confirm-card .city-name { font-family: ‘Inter Tight’, sans-serif; font-size: 1.8rem; font-weight: 800; letter-spacing: -0.035em; margin: 6px 0; }
.confirm-card .country-code { color: var(–fg-muted); font-size: 0.85rem; font-family: ‘JetBrains Mono’, monospace; }
.confirm-buttons { display: grid; grid-template-columns: 1fr 2fr; gap: 8px; margin-top: 16px; }

.error { color: var(–bad); font-size: 0.8rem; min-height: 18px; text-align: center; font-weight: 500; }

/* ── GUESS SCREEN ──────────────────────────────────────────────────────── */
#guess-screen { position: relative; }
#map { flex: 1; width: 100%; cursor: crosshair !important; background: var(–water); }
.leaflet-container { background: var(–water); outline: none; font-family: inherit; }
.leaflet-control-attribution { display: none; }
.leaflet-control-zoom { display: none; }

.guess-overlay {
position: absolute;
top: calc(var(–sa-top) + 60px);
left: 12px; right: 12px;
z-index: 1000;
pointer-events: none;
}
.target-card {
background: hsla(225, 14%, 8%, 0.85);
backdrop-filter: blur(24px) saturate(180%);
-webkit-backdrop-filter: blur(24px) saturate(180%);
border: 1px solid var(–hairline-strong);
border-radius: 18px;
padding: 14px 16px;
display: flex;
align-items: center;
gap: 12px;
box-shadow: 0 8px 32px rgba(0,0,0,0.5);
pointer-events: auto;
}
.target-card .pieces { flex: 1; min-width: 0; }
.target-card .who-line { font-size: 0.7rem; color: var(–fg-muted); font-weight: 500; letter-spacing: 0; display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.target-card .target-name { font-family: ‘Inter Tight’, sans-serif; font-size: 1.15rem; font-weight: 800; letter-spacing: -0.025em; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.target-card .target-name .accent { color: var(–accent); }
.target-card .timer-pill {
flex-shrink: 0;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.85rem;
font-weight: 600;
padding: 6px 10px;
border-radius: 10px;
background: var(–surface-2);
color: var(–fg-muted);
border: 1px solid var(–hairline);
}
.target-card .timer-pill.warn { color: var(–warn); border-color: hsla(38,100%,65%,0.3); background: hsla(38,100%,65%,0.08); }
.target-card .timer-pill.danger { color: var(–bad); border-color: hsla(348,95%,65%,0.3); background: hsla(348,95%,65%,0.08); animation: pulseBad 0.6s ease-in-out infinite; }
@keyframes pulseBad { 0%,100%{transform:scale(1);} 50%{transform:scale(1.06);} }

.hint-card {
margin-top: 8px;
background: hsla(180, 60%, 30%, 0.15);
backdrop-filter: blur(20px) saturate(180%);
border: 1px solid hsla(180, 80%, 50%, 0.25);
border-radius: 14px;
padding: 10px 14px;
font-size: 0.8rem;
color: var(–accent);
font-weight: 500;
display: flex; align-items: center; gap: 8px;
pointer-events: auto;
}

.continent-bar {
position: absolute;
bottom: 88px;
left: 12px; right: 12px;
z-index: 1000;
display: flex;
gap: 6px;
overflow-x: auto;
scrollbar-width: none;
padding: 4px 0;
}
.continent-bar::-webkit-scrollbar { display: none; }
.continent-chip {
flex-shrink: 0;
padding: 8px 14px;
background: hsla(225, 14%, 8%, 0.85);
backdrop-filter: blur(20px);
border: 1px solid var(–hairline);
border-radius: 100px;
color: var(–fg-muted);
font-size: 0.75rem;
font-weight: 600;
cursor: pointer;
transition: all 0.15s;
}
.continent-chip:active { transform: scale(0.94); }

.zoom-controls {
position: absolute;
right: 12px;
bottom: 142px;
z-index: 1000;
display: flex;
flex-direction: column;
gap: 6px;
}
.zoom-btn {
width: 44px; height: 44px;
background: hsla(225, 14%, 8%, 0.85);
backdrop-filter: blur(20px);
border: 1px solid var(–hairline);
border-radius: 12px;
color: var(–fg);
font-size: 1.4rem;
font-weight: 600;
cursor: pointer;
display: grid; place-items: center;
transition: transform 0.1s;
}
.zoom-btn:active { transform: scale(0.92); }

.guess-bar {
display: flex;
gap: 10px;
padding: 12px 12px calc(12px + var(–sa-bot));
background: linear-gradient(180deg, transparent, var(–bg-0) 40%);
flex-shrink: 0;
position: relative;
z-index: 100;
}
.guess-bar .btn { flex: 1; }
.guess-bar .btn-icon { flex: 0 0 50px; }

.tip-toast {
position: absolute;
top: calc(var(–sa-top) + 130px);
left: 50%;
transform: translateX(-50%) translateY(-8px);
background: hsla(0, 0%, 100%, 0.92);
color: hsl(220, 30%, 8%);
padding: 8px 14px;
border-radius: 100px;
font-size: 0.78rem;
font-weight: 600;
z-index: 1000;
opacity: 0;
pointer-events: none;
transition: opacity 0.3s, transform 0.3s var(–ease-spring);
white-space: nowrap;
}
.tip-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ── RESULT SCREEN ─────────────────────────────────────────────────────── */
#result-screen { position: relative; }
#rmap { flex: 1; width: 100%; }
.result-panel {
background: linear-gradient(180deg, transparent, var(–bg-0) 30%);
padding: 20px 18px calc(18px + var(–sa-bot));
flex-shrink: 0;
position: relative;
}
.result-card {
background: hsla(225, 14%, 8%, 0.92);
backdrop-filter: blur(20px);
border: 1px solid var(–hairline-strong);
border-radius: 20px;
padding: 18px;
margin-top: -40px;

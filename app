.hof-row .hof-name { font-weight: 600; font-size: 0.98rem; }
.hof-row .hof-stats { font-size: 0.72rem; color: var(–fg-dim); margin-top: 2px; font-family: ‘JetBrains Mono’, monospace; letter-spacing: 0.02em; }

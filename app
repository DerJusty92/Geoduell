function updateHeaderMeta(){
  const el = document.getElementById('header-meta');
  if(game.roundNum === 0){ el.innerHTML = ''; return; }
  const total = game.settings.roundLimit === 999 ? '∞' : game.settings.roundLimit;
  let html = `<span class="chip live"><strong>${game.roundNum}</strong> / ${total}</span>`;
  // Total sips so far this game
  if(game.settings.drink.enabled && game.drinkLog){
    const totalSips = Object.values(game.drinkLog).reduce((s,v) => s + v, 0);
    if(totalSips > 0){
      html += ` <span class="chip" style="color:hsl(35, 95%, 70%);border-color:hsla(35,95%,70%,0.3);background:hsla(35,95%,70%,0.08);"><strong>${totalSips}</strong> 🍺</span>`;
    }
  }
  el.innerHTML = html;
}


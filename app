// ── DRINK MECHANICS ──────────────────────────────────────────────────────
function logDrinks(playerName, sips){
  if(!game.drinkLog) game.drinkLog = {};
  game.drinkLog[playerName] = (game.drinkLog[playerName] || 0) + sips;
  updateHeaderMeta();
}

function computeRotationDrinks(guesserIdx, dist){
  // Returns { drinks: [{playerName, sips, reason}], requiresPerfectChoice: bool }
  const out = { drinks: [], requiresPerfectChoice: false };
  if(!game.settings.drink.enabled) return out;
  const d = game.settings.drink;
  const guesser = game.players[guesserIdx];
  const picker = game.players[game.pickerIdx];

  // Perfect hit
  if(d.perfectHit && dist < 50){
    out.requiresPerfectChoice = true; // handled via modal
  }
  // Distance penalty
  if(d.distancePenalty && dist >= d.distanceThreshold){
    const sips = dist >= d.distanceThreshold * 2 ? 2 : 1;
    out.drinks.push({ playerName: guesser.name, sips, reason: `${Math.round(dist).toLocaleString('de-DE')} km daneben` });
  }
  // Picker revenge: uses configured threshold
  if(d.pickerRevenge && dist >= d.distanceThreshold && picker.name !== guesser.name){
    out.drinks.push({ playerName: picker.name, sips: 1, reason: 'fiese Stadt gewählt' });
  }

  return out;
}

function computeBattleDrinks(){
  const out = { drinks: [], requiresPerfectChoice: null };
  if(!game.settings.drink.enabled) return out;
  const d = game.settings.drink;
  const picker = game.players[game.pickerIdx];

  // Per-player drinks
  game.battleResults.forEach(r => {
    if(d.distancePenalty && r.dist >= d.distanceThreshold){
      const sips = r.dist >= d.distanceThreshold * 2 ? 2 : 1;
      out.drinks.push({ playerName: r.name, sips, reason: `${r.dist.toLocaleString('de-DE')} km daneben` });
    }
  });

  // Last place this round
  if(d.lastPlace && game.battleResults.length){
    const sorted = [...game.battleResults].sort((a,b) => a.score - b.score);
    const last = sorted[0];
    out.drinks.push({ playerName: last.name, sips: 1, reason: 'Letzter Platz' });
  }

  // Picker revenge: NO ONE got within threshold
  if(d.pickerRevenge && game.battleResults.length){
    const minDist = Math.min(...game.battleResults.map(r => r.dist));
    if(minDist >= d.distanceThreshold){
      out.drinks.push({ playerName: picker.name, sips: 2, reason: 'niemand kam ran' });
    }
  }

  // Perfect hit in battle: best result < 50km
  if(d.perfectHit){
    const best = [...game.battleResults].sort((a,b) => a.dist - b.dist)[0];
    if(best && best.dist < 50){
      out.requiresPerfectChoice = best.playerIdx; // who picks
    }
  }

  return out;
}

function computeRotationLastPlace(){
  // After leaderboard update: who has fewest points THIS ROUND (the guesser if they got 0)
  // For rotation: the guesser of this round earned X points. If lastPlace setting on,
  // and guesser earned the lowest score in this single guess... well there's only one guess.
  // Better interpretation: in rotation, the guesser drinks if dist > some threshold (lastPlace ~ same as distance penalty).
  // Skip for rotation, only meaningful in battle.
  return null;
}

function renderDrinkBanner(drinks){
  if(!drinks || !drinks.length) return '';
  // Aggregate per player
  const agg = {};
  drinks.forEach(d => {
    if(!agg[d.playerName]) agg[d.playerName] = { sips: 0, reasons: [] };
    agg[d.playerName].sips += d.sips;
    agg[d.playerName].reasons.push(d.reason);
  });
  const items = Object.entries(agg).map(([name, info]) => {
    const pIdx = game.players.findIndex(p => p.name === name);
    const c = PLAYER_COLORS[pIdx % PLAYER_COLORS.length];
    logDrinks(name, info.sips);
    return `<div class="drink-item">
      <div class="avatar" style="--player-color:${c.color};--player-color-glow:${c.glow}">${getInitials(name)}</div>
      <div class="who"><div>${escapeHtml(name)}</div><div class="reason">${info.reasons.join(' + ')}</div></div>
      <div class="sips">${info.sips}× 🍺</div>
    </div>`;
  }).join('');
  return `<div class="drink-banner">
    <div class="drink-head">🍻 Trinken muss</div>
    <div class="drink-list">${items}</div>
  </div>`;
}


// Resume banner
function checkResume(){
  const saved = loadState();
  const slot = document.getElementById('resume-slot');
  if(!saved || !saved.players || saved.players.length < 2 || !saved.roundNum){
    slot.innerHTML = '';
    return;
  }
  const ageMs = Date.now() - (saved.startedAt || 0);
  const ageHours = ageMs / 3600000;
  // Auto-discard sessions older than 24 hours
  if(ageHours > 24){
    clearState();
    slot.innerHTML = '';
    return;
  }
  const ageMin = Math.round(ageMs / 60000);
  const ageStr = ageMin < 1 ? 'gerade eben'
                : ageMin < 60 ? `vor ${ageMin}min`
                : ageHours < 6 ? `vor ${Math.round(ageHours)}h`
                : `vor ${Math.round(ageHours)}h`;
  slot.innerHTML = `
    <div class="resume-banner">
      <div class="info">
        <div class="t">Letztes Spiel fortsetzen?</div>
        <div class="s">${saved.players.length} Spieler · Runde ${saved.roundNum} · ${ageStr}</div>
      </div>
      <div class="actions">
        <button class="btn btn-ghost btn-sm" id="discard-resume">×</button>
        <button class="btn btn-primary btn-sm" id="do-resume">Fortsetzen</button>
      </div>
    </div>`;
  document.getElementById('discard-resume').addEventListener('click', () => { clearState(); checkResume(); });
  document.getElementById('do-resume').addEventListener('click', () => {
    Object.assign(game, saved);
    game.players.forEach(p => { if(!p.history) p.history = []; });
    updateHeaderMeta();
    if(game.settings.mode === 'battle') showPassScreen('battle-pick');
    else showPassScreen('pick');
  });
}


.lb-card {
display: grid;
grid-template-columns: 28px auto 1fr auto;
align-items: center;
gap: 12px;
padding: 12px 14px;
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 14px;
cursor: pointer;
transition: all 0.15s;
position: relative;
overflow: hidden;
}
.lb-card:active { transform: scale(0.99); }
.lb-card.lead { border-color: var(–hairline-strong); background: var(–surface-2); }
.lb-card.lead::before { content: ‘’; position: absolute; inset: 0; background: linear-gradient(135deg, hsla(180, 90%, 55%, 0.08), transparent 50%); pointer-events: none; }
.lb-rank { font-family: ‘Inter Tight’, sans-serif; font-weight: 800; font-size: 1.2rem; color: var(–fg-dim); text-align: center; }
.lb-rank.gold { color: hsl(45, 100%, 65%); }
.lb-rank.silver { color: hsl(220, 10%, 75%); }
.lb-rank.bronze { color: hsl(28, 65%, 62%); }
.lb-name-block { min-width: 0; }
.lb-name { font-weight: 600; font-size: 0.98rem; letter-spacing: -0.015em; }
.lb-meta { font-size: 0.7rem; color: var(–fg-dim); margin-top: 2px; font-family: ‘JetBrains Mono’, monospace; letter-spacing: 0.02em; }
.lb-pts { text-align: right; }
.lb-pts .v { font-family: ‘Inter Tight’, sans-serif; font-weight: 800; font-size: 1.2rem; color: var(–good); letter-spacing: -0.025em; }
.lb-pts .u { font-size: 0.65rem; color: var(–fg-dim); display: block; margin-top: 1px; }
.lb-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 16px; }

/* History modal */
.history-sheet {
position: fixed; inset: 0;
background: rgba(0,0,0,0.7);
z-index: 200;
display: none;
align-items: flex-end;
animation: fadeIn 0.2s;
}
.history-sheet.open { display: flex; }
.history-content {
width: 100%;
background: var(–bg-1);
border-top: 1px solid var(–hairline-strong);
border-radius: 24px 24px 0 0;
padding: 16px 18px calc(20px + var(–sa-bot));
max-height: 85vh;
overflow-y: auto;
animation: slideUp 0.3s var(–ease-spring);
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: none; } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.sheet-grabber { width: 40px; height: 4px; background: var(–hairline-strong); border-radius: 2px; margin: 0 auto 12px; }
.history-row {
display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 12px;
padding: 11px 0;
border-bottom: 1px solid var(–hairline);
}
.history-row:last-child { border-bottom: none; }
.history-row .h-city { font-weight: 600; font-size: 0.9rem; }
.history-row .h-meta { font-size: 0.7rem; color: var(–fg-dim); margin-top: 2px; font-family: ‘JetBrains Mono’, monospace; }
.history-row .h-dist { font-family: ‘JetBrains Mono’, monospace; color: var(–fg-muted); font-size: 0.78rem; }
.history-row .h-pts { font-family: ‘Inter Tight’, sans-serif; font-weight: 700; color: var(–good); }

/* ── ENDGAME ───────────────────────────────────────────────────────────── */
.end-trophy {
font-size: 4.5rem; line-height: 1;
display: block;
text-align: center;
margin: 20px 0 12px;
filter: drop-shadow(0 8px 24px hsla(45, 100%, 50%, 0.4));
animation: trophy 2s ease-in-out infinite;
}
@keyframes trophy {
0%,100% { transform: translateY(0) rotate(-3deg); }
50% { transform: translateY(-6px) rotate(3deg); }
}
.podium {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 10px;
align-items: end;
margin: 24px 0;
}
.podium-col { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.podium-name { font-weight: 700; font-size: 0.85rem; text-align: center; }
.podium-pts { font-family: ‘Inter Tight’, sans-serif; font-weight: 800; font-size: 1rem; color: var(–good); }
.podium-bar { width: 100%; border-radius: 12px 12px 4px 4px; display: grid; place-items: center; font-size: 1.6rem; }
.podium-bar.gold { background: linear-gradient(180deg, hsl(45, 100%, 60%), hsl(35, 90%, 45%)); height: 110px; }
.podium-bar.silver { background: linear-gradient(180deg, hsl(220, 10%, 80%), hsl(220, 8%, 55%)); height: 80px; }
.podium-bar.bronze { background: linear-gradient(180deg, hsl(28, 70%, 65%), hsl(20, 55%, 40%)); height: 60px; }

.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 16px 0; }
.stat-card {
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 14px;
padding: 12px;
}
.stat-card .label { font-size: 0.65rem; margin-bottom: 4px; }
.stat-card .v { font-family: ‘Inter Tight’, sans-serif; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.025em; }
.stat-card .sub { font-size: 0.72rem; color: var(–fg-muted); margin-top: 2px; }

/* ── RESUME PROMPT ─────────────────────────────────────────────────────── */
.resume-banner {
margin: 14px 0 20px;
padding: 14px;
background: var(–surface-2);
border: 1px solid var(–accent-soft);
border-radius: 14px;
display: flex;
align-items: center;
gap: 12px;
}
.resume-banner .info { flex: 1; min-width: 0; }
.resume-banner .info .t { font-weight: 600; font-size: 0.9rem; margin-bottom: 2px; }
.resume-banner .info .s { font-size: 0.75rem; color: var(–fg-muted); }
.resume-banner .actions { display: flex; gap: 6px; }

/* ── MARKERS ON MAP ────────────────────────────────────────────────────── */
.target-pin {
width: 22px; height: 22px;
border-radius: 50%;
background: var(–accent);
border: 3px solid white;
box-shadow: 0 0 0 2px var(–bg-0), 0 0 24px var(–accent), 0 0 0 12px hsla(180, 90%, 55%, 0.15);
animation: pinDrop 0.5s var(–ease-spring);
}

// HoF screen
let hofSortMode = 'total';

function showHofScreen(){
  const profiles = loadProfiles();
  let sorted = Object.values(profiles);
  let primaryFn, primaryUnit, primaryLabel;
  if(hofSortMode === 'total'){
    primaryFn = p => p.totalPoints;
    primaryUnit = 'total pts'; primaryLabel = (v) => v.toLocaleString('de-DE');
  } else if(hofSortMode === 'avg'){
    primaryFn = p => p.gamesPlayed ? Math.round(p.totalPoints / p.gamesPlayed) : 0;
    primaryUnit = '⌀ pro Spiel'; primaryLabel = (v) => v.toLocaleString('de-DE');
  } else if(hofSortMode === 'wins'){
    primaryFn = p => p.wins || 0;
    primaryUnit = 'Siege'; primaryLabel = (v) => v + '🏆';
  } else if(hofSortMode === 'sips'){
    primaryFn = p => p.totalSips || 0;
    primaryUnit = 'Schlucke'; primaryLabel = (v) => v + '🍺';
  }
  sorted.sort((a,b) => primaryFn(b) - primaryFn(a));

  const list = document.getElementById('hof-list');
  if(!sorted.length){
    list.innerHTML = '<div class="empty-state">Noch keine gespeicherten Spieler</div>';
  } else {
    list.innerHTML = sorted.map((p, rank) => {
      const c = PLAYER_COLORS[rank % PLAYER_COLORS.length];
      const rankCls = rank === 0 ? 'gold' : rank === 1 ? 'silver' : rank === 2 ? 'bronze' : '';
      const avgPerGame = p.gamesPlayed ? Math.round(p.totalPoints / p.gamesPlayed).toLocaleString('de-DE') : 0;
      const winRate = p.gamesPlayed ? Math.round((p.wins||0) / p.gamesPlayed * 100) : 0;
      const primaryVal = primaryFn(p);

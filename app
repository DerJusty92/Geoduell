cinput.addEventListener('input', () => {
  game._selectedCity = null;
  const q = cinput.value.trim();
  if(q.length < 2){ sbox.style.display = 'none'; return; }
  const res = searchCities(q, getCityPool());
  if(!res.length){ sbox.style.display = 'none'; return; }
  sbox.innerHTML = res.map((c,i) => `<div class="si" data-i="${i}" data-name="${escapeHtml(c.name)}" data-lat="${c.lat}" data-lng="${c.lng}" data-country="${c.country}"><span>${escapeHtml(c.name)}</span><span class="si-country">${c.country||''}</span></div>`).join('');
  sbox.style.display = 'block';
  hiIdx = -1;
  sbox.querySelectorAll('.si').forEach(el => el.addEventListener('click', () => pickSuggestion(el)));
});

cinput.addEventListener('keydown', e => {
  const items = sbox.querySelectorAll('.si');
  if(e.key === 'ArrowDown'){ hiIdx = Math.min(hiIdx+1, items.length-1); hl(items); e.preventDefault(); }
  else if(e.key === 'ArrowUp'){ hiIdx = Math.max(hiIdx-1, 0); hl(items); e.preventDefault(); }
  else if(e.key === 'Enter'){
    if(hiIdx >= 0 && items[hiIdx]){ pickSuggestion(items[hiIdx]); e.preventDefault(); }
    else attemptConfirmCity();
  }
});

function hl(items){ items.forEach((el,i) => el.classList.toggle('hi', i===hiIdx)); }

function pickSuggestion(el){
  game._selectedCity = {
    name: el.dataset.name,
    lat: parseFloat(el.dataset.lat),
    lng: parseFloat(el.dataset.lng),
    country: el.dataset.country,
  };
  cinput.value = game._selectedCity.name;
  sbox.style.display = 'none';
  attemptConfirmCity();
}


function searchCities(q, maxPool){
  q = norm(q);
  if(q.length < 2) return [];
  const limit = maxPool || CITIES.length;
  const filterDistricts = (game.settings && game.settings.difficulty) !== 'hard' && maxPool && maxPool < CITIES.length;
  const res = [], seen = new Set();
  for(let i=0; i<limit; i++){
    const c = CITIES[i];
    const lat=c[0], lng=c[1], name=c[2], country=c[3], aliases=c[4]||[];
    if(filterDistricts && isSubDistrict(name)) continue;
    const nn = norm(name);
    const key = nn+'|'+country;
    if(seen.has(key)) continue;
    const all = [nn, ...aliases.map(norm)];
    let s = 0;
    for(const a of all){
      if(a === q){ s = 3; break; }
      else if(a.startsWith(q)){ if(s<2) s=2; }
      else if(a.includes(q)){ if(s<1) s=1; }
    }
    if(s){
      const popBoost = 1 - i/limit;
      const districtPenalty = isSubDistrict(name) ? -0.5 : 0;
      res.push({lat,lng,name,country,score:s+popBoost+districtPenalty,popIdx:i});
      seen.add(key);
    }
    if(res.length > 200) break;
  }
  return res.sort((a,b)=>b.score-a.score).slice(0,8);
}

function isSubDistrict(name){
  return /-[A-ZÄÖÜ]/.test(name) || /\bdistrict\b/i.test(name) ||
         /\bShi\b/.test(name) || /^.+ [a-z]+kommun$/.test(name) ||
         / Köpenick$| Friedrichshain$| Spandau$| Pankow$| Mitte$/.test(name);
}

function getCityPool(){
  const map = { easy: 500, medium: 2000, hard: CITIES.length };
  return map[game.settings.difficulty] || CITIES.length;
}

function getCityPoolList(){
  // Returns filtered list of city indices for current difficulty
  const limit = getCityPool();
  const filterDistricts = game.settings.difficulty !== 'hard';
  const indices = [];
  for(let i=0; i<limit; i++){
    if(filterDistricts && isSubDistrict(CITIES[i][2])) continue;
    indices.push(i);
  }
  return indices;
}

function pickRandomCity(){
  const list = getCityPoolList();
  const idx = list[Math.floor(Math.random() * list.length)];
  const c = CITIES[idx];
  return { lat: c[0], lng: c[1], name: c[2], country: c[3] };
}


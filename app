.rank-change.down { background: hsla(348, 95%, 65%, 0.12); color: var(–bad); }
.rank-change.same { background: var(–surface-2); color: var(–fg-muted); }

.next-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 14px; }

/* For battle mode: showing all guesses */
.battle-results { display: flex; flex-direction: column; gap: 8px; max-height: 240px; overflow-y: auto; margin-top: 10px; }
.battle-row { display: grid; grid-template-columns: auto auto 1fr auto auto; gap: 10px; align-items: center; padding: 10px 12px; background: var(–surface-1); border: 1px solid var(–hairline); border-radius: 12px; }
.battle-row .pos { font-family: ‘Inter Tight’, sans-serif; font-weight: 800; color: var(–fg-muted); font-size: 0.95rem; min-width: 18px; }
.battle-row .pos.gold { color: hsl(45, 100%, 65%); }
.battle-row .name { font-weight: 600; font-size: 0.9rem; }
.battle-row .dist { font-family: ‘JetBrains Mono’, monospace; font-size: 0.78rem; color: var(–fg-muted); }
.battle-row .pts { font-family: ‘Inter Tight’, sans-serif; font-weight: 700; color: var(–good); font-size: 0.95rem; }

/* ── LEADERBOARD ───────────────────────────────────────────────────────── */
.lb-header { text-align: center; margin: 20px 0 22px; }

function showPassScreen(nextAction){
  const passAvatar = document.getElementById('pass-avatar');
  const passInitials = document.getElementById('pass-initials');
  const passName = document.getElementById('pass-name');
  const passAction = document.getElementById('pass-action');
  const passWarn = document.getElementById('pass-warn');
  const passEyebrow = document.getElementById('pass-eyebrow');
  const continueBtn = document.getElementById('pass-continue');

  let activeIdx, actionHtml, warn = false, eyebrow = 'Handy weitergeben an';

  if(nextAction === 'pick'){
    activeIdx = game.pickerIdx;
    const target = game.players[game.guesserIdx];
    actionHtml = `Wähle eine Stadt für <strong>${escapeHtml(target.name)}</strong>`;
  } else if(nextAction === 'guess'){
    activeIdx = game.guesserIdx;
    const picker = game.players[game.pickerIdx];
    actionHtml = `Finde die Stadt, die <strong>${escapeHtml(picker.name)}</strong> gewählt hat`;
    warn = true;
  } else if(nextAction === 'battle-pick'){
    // Random picker each round (rotates)
    activeIdx = game.pickerIdx;
    actionHtml = `Wähle eine Stadt — alle anderen raten dieselbe`;
    eyebrow = 'Stadt-Wähler dieser Runde';
  } else if(nextAction === 'battle-guess'){
    activeIdx = game.battleQueueIdx;
    eyebrow = `Spieler ${countBattleDone() + 1} von ${countBattleTotal()}`;
    actionHtml = `Finde die Stadt`;
    warn = true;
  }

  applyPlayerColor(passAvatar, activeIdx);
  passInitials.textContent = getInitials(game.players[activeIdx].name);
  passName.textContent = game.players[activeIdx].name;
  passAction.innerHTML = actionHtml;
  passEyebrow.textContent = eyebrow;
  passWarn.classList.toggle('hide', !warn);

  vibrate([30, 50, 30]);

  continueBtn.onclick = () => {
    vibrate(20);
    if(nextAction === 'pick' || nextAction === 'battle-pick') showPickScreen();
    else showGuessScreen();
  };

  showScreen('screen-pass');
}


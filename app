// ── EUROPE BONUS ──────────────────────────────────────────────────────────
function isInEurope(lat, lng){
  // Rough Europe bounding box (incl. western Russia, but excl. Turkey/most of Russia)
  return lat >= 35 && lat <= 71 && lng >= -25 && lng <= 45;
}

// ── TIMER ─────────────────────────────────────────────────────────────────
function startTimerIfEnabled(){
  stopTimer();
  const t = game.settings.timer;
  const pill = document.getElementById('timer-pill');
  if(t <= 0){ pill.classList.add('hide'); return; }
  pill.classList.remove('hide');
  game._timerLeft = t;
  updateTimerDisplay();
  game._timerInterval = setInterval(() => {
    game._timerLeft--;
    updateTimerDisplay();
    if(game._timerLeft <= 0){
      stopTimer();
      // Force submission
      if(!game.guess){
        // Random guess as penalty
        game.guess = { lat: 0, lng: 0 };
      }
      vibrate([100, 50, 100]);
      finishGuess(true);
    } else if(game._timerLeft === 5){
      vibrate(50);
    }
  }, 1000);
}
function stopTimer(){
  if(game._timerInterval){ clearInterval(game._timerInterval); game._timerInterval = null; }
}
function updateTimerDisplay(){
  const pill = document.getElementById('timer-pill');
  const m = Math.floor(game._timerLeft / 60);
  const s = game._timerLeft % 60;
  pill.textContent = m > 0 ? `${m}:${String(s).padStart(2,'0')}` : `${s}s`;
  pill.classList.toggle('warn', game._timerLeft <= 10 && game._timerLeft > 5);
  pill.classList.toggle('danger', game._timerLeft <= 5);
}

// ── FINISH GUESS ──────────────────────────────────────────────────────────
function computeRanks(){
  const sorted = game.players.map((p,i) => ({i, pts: p.points})).sort((a,b)=>b.pts-a.pts);
  const ranks = {};
  sorted.forEach((s, rank) => { ranks[s.i] = rank; });
  game.prevRanks = ranks;
}

function finishGuess(timeout){
  const activeIdx = game.settings.mode === 'battle' ? game.battleQueueIdx : game.guesserIdx;
  const player = game.players[activeIdx];

  let dist;
  if(timeout && (game.guess.lat === 0 && game.guess.lng === 0)){
    dist = 9999; // huge penalty
  } else {
    dist = haversine(game.target.lat, game.target.lng, game.guess.lat, game.guess.lng);
  }
  let score = calcScore(dist, game.hintUsed);

  // Europe bonus: +25% if target was in Europe
  const europeBonus = isInEurope(game.target.lat, game.target.lng);
  if(europeBonus) score = Math.round(score * 1.25);

  // Streak bonus check (3 in a row under 500km)
  const recentClose = player.history.slice(-2).filter(h => h.dist < 500).length;
  let streakBonus = 0;
  if(recentClose === 2 && dist < 500){
    streakBonus = 1000;
    score += streakBonus;
  }

  // Picker also gets points if guesser landed in sweet spot (300-1500km)
  let pickerBonus = 0;
  if(game.settings.mode === 'rotation' && dist >= 300 && dist <= 1500){
    pickerBonus = 500;
    game.players[game.pickerIdx].points += pickerBonus;
  }

  // Save before mutation
  const prevRank = game.prevRanks[activeIdx];

  player.points += score;
  player.rounds += 1;
  player.history.push({
    city: game.target.name,
    country: game.target.country,
    dist: Math.round(dist),
    pts: score,
    hint: game.hintGiven,
    pickerName: game.settings.mode === 'rotation' ? game.players[game.pickerIdx].name : null,
  });

  // Battle mode: collect this guess and show pass for next player
  if(game.settings.mode === 'battle'){
    game.battleResults.push({
      playerIdx: activeIdx, name: player.name,
      guess: {...game.guess},
      dist: Math.round(dist),
      score, hintUsed: game.hintUsed,
    });
    saveState();
    // Check if more players to guess
    if(game.battleResults.length < countBattleTotal()){
      game.battleQueueIdx = nextBattleGuesser(game.battleQueueIdx);
      showPassScreen('battle-guess');
      return;
    }
    // All battle guesses done -> show battle result
    showBattleResult();
    return;
  }

  // Rotation mode: show single result
  showSingleResult({ dist, score, prevRank, europeBonus, streakBonus, pickerBonus, timeout });
}


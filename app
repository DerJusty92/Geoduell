}

function updateProfilesAfterGame(){
  const profiles = loadProfiles();
  const sorted = [...game.players].sort((a,b)=>b.points-a.points);
  const winnerName = sorted[0]?.name;
  game.players.forEach((p, i) => {
    if(!profiles[p.name]){
      profiles[p.name] = {
        name: p.name, gamesPlayed: 0, totalPoints: 0,
        totalRounds: 0, wins: 0, bestPoints: 0,
        bestGuess: null, lastPlayed: 0, totalSips: 0,
      };
    }
    const prof = profiles[p.name];
    prof.gamesPlayed += 1;
    prof.totalPoints += p.points;
    prof.totalRounds += p.rounds || 0;
    prof.lastPlayed = Date.now();
    if(p.name === winnerName && p.points > 0) prof.wins += 1;
    if(p.points > (prof.bestPoints || 0)) prof.bestPoints = p.points;
    // Best single guess?
    if(p.history && p.history.length){
      const minDist = p.history.reduce((m, h) => Math.min(m, h.dist), Infinity);
      if(!prof.bestGuess || minDist < prof.bestGuess.dist){
        const bg = p.history.find(h => h.dist === minDist);
        prof.bestGuess = { city: bg.city, country: bg.country, dist: bg.dist };
      }
    }
    // Sips
    if(game.drinkLog && game.drinkLog[p.name]){
      prof.totalSips = (prof.totalSips || 0) + game.drinkLog[p.name];
    }
  });
  saveProfiles(profiles);
}

function renderKnownPlayers(){
  const slot = document.getElementById('known-players-slot');
  const profiles = loadProfiles();
  const known = Object.values(profiles)
    .sort((a,b) => b.lastPlayed - a.lastPlayed)
    .slice(0, 12);
  if(!known.length){ slot.innerHTML = ''; return; }
  const taken = new Set(game.players.map(p => p.name.toLowerCase()));
  slot.innerHTML = `
    <div class="known-header">
      <div class="label">Bekannte Spieler <span style="color:var(--fg-dim);font-weight:400;font-size:0.7rem;letter-spacing:0;">· lang drücken zum Entfernen</span></div>
      <button class="link-btn" id="open-hof">Hall of Fame →</button>
    </div>
    <div class="known-players">
      ${known.map((p, i) => {
        const c = PLAYER_COLORS[i % PLAYER_COLORS.length];
        const t = taken.has(p.name.toLowerCase()) ? ' taken' : '';
        return `<div class="known-chip${t}" data-name="${escapeHtml(p.name)}">
          <div class="avatar sm" style="--player-color:${c.color};--player-color-glow:${c.glow}">${getInitials(p.name)}</div>
          <span>${escapeHtml(p.name)}</span>
          <span class="chip-stats">${p.gamesPlayed}× · ${p.wins}🏆</span>
        </div>`;
      }).join('')}
    </div>
  `;
  slot.querySelectorAll('.known-chip').forEach(chip => {
    let pressTimer = null, longPressed = false;
    const startPress = () => {
      longPressed = false;
      pressTimer = setTimeout(() => {
        longPressed = true;
        const name = chip.dataset.name;
        if(confirm(`„${name}" aus Bekannte Spieler entfernen?`)){
          const profiles = loadProfiles();
          delete profiles[name];
          saveProfiles(profiles);
          renderKnownPlayers();
          vibrate([30, 50, 30]);
        }
      }, 600);
    };
    const cancelPress = () => { if(pressTimer){ clearTimeout(pressTimer); pressTimer = null; } };
    chip.addEventListener('touchstart', startPress, {passive: true});
    chip.addEventListener('touchend', cancelPress);
    chip.addEventListener('touchmove', cancelPress);
    chip.addEventListener('touchcancel', cancelPress);
    chip.addEventListener('mousedown', startPress);
    chip.addEventListener('mouseup', cancelPress);
    chip.addEventListener('mouseleave', cancelPress);
    chip.addEventListener('click', (e) => {
      if(longPressed){ e.preventDefault(); return; }
      if(chip.classList.contains('taken')) return;
      const name = chip.dataset.name;
      if(game.players.length >= 8) return;
      if(game.players.some(p => p.name.toLowerCase() === name.toLowerCase())) return;
      game.players.push({ name, points: 0, rounds: 0, history: [] });
      renderPlayerList();
      renderKnownPlayers();
      updateButtons();
      vibrate(20);
    });
  });
  document.getElementById('open-hof').addEventListener('click', showHofScreen);
}


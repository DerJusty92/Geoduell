.score-bar { height: 4px; background: var(–surface-2); border-radius: 2px; overflow: hidden; margin: 14px 0 12px; }
.score-fill { height: 100%; width: 0; transition: width 1.2s var(–ease-out); background: linear-gradient(90deg, var(–bad) 0%, var(–warn) 50%, var(–good) 100%); border-radius: 2px; }

.direction-hint {

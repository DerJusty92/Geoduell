function computeContinentDrinks(allHistory){
  // Determine continent from lat/lng
  const continents = {
    europe: { name: 'Europa', icon: '🇪🇺', dists: [] },
    asia: { name: 'Asien', icon: '🌏', dists: [] },
    africa: { name: 'Afrika', icon: '🌍', dists: [] },
    namerica: { name: 'Nordamerika', icon: '🇺🇸', dists: [] },
    samerica: { name: 'Südamerika', icon: '🇧🇷', dists: [] },
    oceania: { name: 'Ozeanien', icon: '🇦🇺', dists: [] },
  };
  function getContinent(lat, lng){
    if(lat >= 35 && lat <= 71 && lng >= -25 && lng <= 60) return 'europe';
    if(lng >= -170 && lng <= -50 && lat >= 7) return 'namerica';
    if(lng >= -90 && lng <= -30 && lat < 7) return 'samerica';
    if(lng >= -20 && lng <= 55 && lat < 35 && lat >= -40) return 'africa';
    if(lat >= -50 && lat <= 5 && lng >= 110 && lng <= 180) return 'oceania';
    return 'asia';
  }
  // Need to find the lat/lng of each city — look it up from CITIES array
  // We have name + country from history. Search.
  function findCity(name, country){
    const nn = norm(name);
    for(let i = 0; i < CITIES.length; i++){
      const c = CITIES[i];
      if(norm(c[2]) === nn && c[3] === country) return { lat: c[0], lng: c[1] };
    }
    return null;
  }

  allHistory.forEach(h => {
    const loc = findCity(h.city, h.country);
    if(!loc) return;
    const cont = getContinent(loc.lat, loc.lng);
    continents[cont].dists.push(h.dist);
  });

  return Object.values(continents)
    .filter(c => c.dists.length > 0)
    .map(c => ({
      name: c.name,
      icon: c.icon,
      tipps: c.dists.length,
      avgDist: Math.round(c.dists.reduce((s, d) => s + d, 0) / c.dists.length),
    }))
    .sort((a, b) => b.avgDist - a.avgDist);
}


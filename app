function attemptConfirmCity(){
  const err = document.getElementById('pick-err');
  let city = game._selectedCity;
  if(!city){
    const q = cinput.value.trim();
    if(!q){ err.textContent = '✗ Stadt eingeben'; return; }
    const res = searchCities(q, getCityPool());
    if(!res.length){ err.textContent = '✗ Stadt nicht gefunden'; return; }
    city = res[0];
  }
  err.textContent = '';
  game.target = { lat: city.lat, lng: city.lng, name: city.name, country: city.country };
  showConfirmScreen();
}


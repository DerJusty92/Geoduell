    const c = PLAYER_COLORS[d.p.origIdx % PLAYER_COLORS.length];
    return `<div class="podium-col">
      <div class="avatar lg" style="--player-color:${c.color};--player-color-glow:${c.glow}">${getInitials(d.p.name)}</div>
      <div class="podium-name">${escapeHtml(d.p.name)}</div>
      <div class="podium-pts">${d.p.points.toLocaleString('de-DE')}</div>
      <div class="podium-bar ${d.cls}">${d.icon}</div>
    </div>`;
  }).join('');

  // Stats
  const allHistory = [];
  game.players.forEach(p => p.history.forEach(h => allHistory.push({...h, player: p.name})));
  const bestGuess = allHistory.length ? allHistory.reduce((b,h) => !b || h.dist < b.dist ? h : b, null) : null;
  const worstGuess = allHistory.length ? allHistory.reduce((w,h) => !w || h.dist > w.dist ? h : w, null) : null;
  const totalDist = allHistory.reduce((s,h) => s+h.dist, 0);
  const avgDist = allHistory.length ? Math.round(totalDist / allHistory.length) : 0;

  // Most Evil Picker: avg distance of all guesses for cities they picked
  const pickerStats = {};
  allHistory.forEach(h => {
    if(!h.pickerName) return;
    if(!pickerStats[h.pickerName]) pickerStats[h.pickerName] = { total: 0, count: 0 };
    pickerStats[h.pickerName].total += h.dist;
    pickerStats[h.pickerName].count += 1;
  });
  const evilEntries = Object.entries(pickerStats)
    .filter(([n, s]) => s.count >= 2)
    .map(([n, s]) => ({ name: n, avg: Math.round(s.total / s.count), count: s.count }))
    .sort((a, b) => b.avg - a.avg);
  const mostEvil = evilEntries[0];

  // Continent stats from drinks
  const continentDrinks = computeContinentDrinks(allHistory);

  const stats = document.getElementById('end-stats');
  stats.innerHTML = `
    ${bestGuess ? `<div class="stat-card"><div class="label">Bester Tipp</div><div class="v">${bestGuess.dist.toLocaleString('de-DE')} km</div><div class="sub">${escapeHtml(bestGuess.player)} · ${escapeHtml(bestGuess.city)}</div></div>` : ''}
    ${worstGuess ? `<div class="stat-card"><div class="label">Daneben-Champion</div><div class="v">${worstGuess.dist.toLocaleString('de-DE')} km</div><div class="sub">${escapeHtml(worstGuess.player)} · ${escapeHtml(worstGuess.city)}</div></div>` : ''}
    <div class="stat-card"><div class="label">Ø Entfernung</div><div class="v">${avgDist.toLocaleString('de-DE')} km</div><div class="sub">über alle Tipps</div></div>
    <div class="stat-card"><div class="label">Runden</div><div class="v">${game.roundNum}</div><div class="sub">${allHistory.length} Tipps insgesamt</div></div>
    ${mostEvil ? `<div class="stat-card" style="grid-column: span 2;"><div class="label">😈 Fiesester Picker</div><div class="v">${escapeHtml(mostEvil.name)}</div><div class="sub">⌀ ${mostEvil.avg.toLocaleString('de-DE')} km auf seine Städte (${mostEvil.count}×)</div></div>` : ''}
  `;

  // Continent drinks summary
  if(continentDrinks && continentDrinks.length){
    const contWrap = document.createElement('div');
    contWrap.id = 'continent-stats';
    contWrap.innerHTML = `
      <div class="label" style="margin-top:14px;">🌍 Schwierige Kontinente</div>
      <div class="stack stack-sm">
        ${continentDrinks.map(c => `<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--surface-1);border:1px solid var(--hairline);border-radius:10px;font-size:0.86rem;">
          <span style="font-size:1.3rem;">${c.icon}</span>
          <span style="flex:1;font-weight:600;">${c.name}</span>
          <span style="font-family:'JetBrains Mono', monospace;color:var(--fg-muted);font-size:0.78rem;">⌀ ${c.avgDist.toLocaleString('de-DE')} km</span>
          <span style="font-family:'Inter Tight', sans-serif;font-weight:700;color:hsl(35, 95%, 70%);">${c.tipps} Tipp${c.tipps !== 1 ? 's' : ''}</span>
        </div>`).join('')}
      </div>
    `;
    // Remove if exists
    const existing = document.getElementById('continent-stats');
    if(existing) existing.remove();
    // Insert after stats grid
    stats.parentNode.insertBefore(contWrap, stats.nextSibling);
  } else {
    const existing = document.getElementById('continent-stats');
    if(existing) existing.remove();
  }

  // Drink summary
  const drinkSummaryEl = document.getElementById('drink-summary');
  if(drinkSummaryEl) drinkSummaryEl.remove();
  if(game.drinkLog && Object.keys(game.drinkLog).length){
    const wrap = document.createElement('div');
    wrap.id = 'drink-summary';
    wrap.className = 'drink-summary';
    const sortedDrinks = Object.entries(game.drinkLog).sort((a,b) => b[1] - a[1]);
    wrap.innerHTML = `
      <div class="label" style="margin-top:14px;">🍻 Trink-Bilanz</div>
      ${sortedDrinks.map(([name, sips]) => {
        const idx = game.players.findIndex(p => p.name === name);
        const c = PLAYER_COLORS[(idx >= 0 ? idx : 0) % PLAYER_COLORS.length];
        return `<div class="drink-summary-row">
          <div class="avatar sm" style="--player-color:${c.color};--player-color-glow:${c.glow}">${getInitials(name)}</div>
          <div class="who">${escapeHtml(name)}</div>
          <div class="total">${sips}× 🍺</div>
        </div>`;
      }).join('')}
    `;
    // Insert before play-again button
    const playAgain = document.getElementById('play-again-btn');
    playAgain.parentNode.parentNode.insertBefore(wrap, playAgain.parentNode);
  }

  // Update lifetime profiles
  updateProfilesAfterGame();

  showScreen('screen-end');
  clearState();
}

document.getElementById('play-again-btn').addEventListener('click', () => {
  game._gameEnded = false;
  game.players.forEach(p => { p.points = 0; p.rounds = 0; p.history = []; });
  game.drinkLog = {};
  game.roundNum = 1;
  game.pickerIdx = 0;
  game.guesserIdx = 1 % game.players.length;
  game.battleQueueIdx = 0;
  game.battleResults = [];
  game.playedCities = [];
  game.startedAt = Date.now();
  computeRanks();
  updateHeaderMeta();
  saveState();
  if(game.settings.mode === 'battle') showPassScreen('battle-pick');
  else showPassScreen('pick');
});

document.getElementById('new-players-btn').addEventListener('click', () => {
  game._gameEnded = false;
  game.players = [];
  game.roundNum = 0;
  game.playedCities = [];
  clearState();
  renderPlayerList();
  updateButtons();
  updateHeaderMeta();
  showScreen('screen-players');
  checkResume();
});

// ── INIT ──────────────────────────────────────────────────────────────────
renderPlayerList();
updateButtons();
checkResume();


</script>

</body>
</html>
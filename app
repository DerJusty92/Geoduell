function applyPlayerColor(el, idx){
  if(idx == null || !el) return;
  const c = PLAYER_COLORS[idx % PLAYER_COLORS.length];
  el.style.setProperty('--player-color', c.color);
  el.style.setProperty('--player-color-deep', c.deep);
  el.style.setProperty('--player-color-glow', c.glow);
}

function getInitials(name){
  const trimmed = name.trim().replace(/\s+/g, '');
  return trimmed.slice(0, 2).toUpperCase() || '?';
}

// ── HELPERS ───────────────────────────────────────────────────────────────
function norm(s){return s.toLowerCase().trim().replace(/ä/g,'a').replace(/ö/g,'o').replace(/ü/g,'u').replace(/ß/g,'ss').replace(/é|è|ê/g,'e').replace(/á|à|â/g,'a').replace(/ó|ô/g,'o').replace(/í|î/g,'i').replace(/ú|û/g,'u').replace(/ñ/g,'n').replace(/ç/g,'c').replace(/[^a-z0-9 ]/g,'');}

function escapeHtml(s){return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}

function haversine(a,b,c,d){
  const R=6371,dL=(c-a)*Math.PI/180,dl=(d-b)*Math.PI/180;
  const x=Math.sin(dL/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dl/2)**2;
  return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));
}

// Steeper score curve - 4000km daneben gibt jetzt nur ~135pts statt 700
function calcScore(km, hintUsed){
  let s;
  if(km < 1) s = 5000;
  else if(km < 25) s = Math.round(5000 - (km/25) * 250); // very close
  else s = Math.round(5000 * Math.exp(-km / 1300));
  if(hintUsed) s = Math.round(s * 0.7); // hint penalty
  return Math.max(0, s);
}

function compassDirection(fromLat, fromLng, toLat, toLng){
  // Returns direction FROM guess TO target (where you should have aimed)
  const dLat = toLat - fromLat;
  const dLng = toLng - fromLng;
  const angle = Math.atan2(dLng, dLat) * 180 / Math.PI; // 0=N, 90=E
  const norm = (angle + 360) % 360;
  const dirs = [
    {min:337.5,max:22.5,label:'Norden',icon:'⬆️'},
    {min:22.5,max:67.5,label:'Nordosten',icon:'↗️'},
    {min:67.5,max:112.5,label:'Osten',icon:'➡️'},
    {min:112.5,max:157.5,label:'Südosten',icon:'↘️'},
    {min:157.5,max:202.5,label:'Süden',icon:'⬇️'},
    {min:202.5,max:247.5,label:'Südwesten',icon:'↙️'},
    {min:247.5,max:292.5,label:'Westen',icon:'⬅️'},
    {min:292.5,max:337.5,label:'Nordwesten',icon:'↖️'},
  ];
  for(const d of dirs){
    if(d.min > d.max){ if(norm >= d.min || norm < d.max) return d; }
    else if(norm >= d.min && norm < d.max) return d;
  }
  return dirs[0];
}

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

function vibrate(ms){

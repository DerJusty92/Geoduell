}
.guess-pin:active { cursor: grabbing; }
@keyframes pinDrop {
0% { transform: scale(0) translateY(-20px); opacity: 0; }
60% { transform: scale(1.2) translateY(0); opacity: 1; }
100% { transform: scale(1); }
}
.battle-pin {
width: 18px; height: 18px;
border-radius: 50%;
border: 2px solid white;
box-shadow: 0 0 0 1.5px var(–bg-0), 0 0 12px var(–player-color-glow);
background: var(–player-color);
}

.leaflet-marker-icon { transition: filter 0.2s; }

/* ── UTILITIES ─────────────────────────────────────────────────────────── */
.hide { display: none !important; }
.flex-1 { flex: 1; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.text-center { text-align: center; }
.text-muted { color: var(–fg-muted); }
.text-dim { color: var(–fg-dim); }
.text-sm { font-size: 0.85rem; }
.text-xs { font-size: 0.75rem; }
.w-full { width: 100%; }

/* ── EXPLAINER CARDS ──────────────────────────────────────────────────── */
.explainer {
margin-top: 10px;
padding: 12px 14px;
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 12px;
font-size: 0.85rem;
line-height: 1.5;
color: var(–fg-muted);
}
.explainer strong { color: var(–fg); font-weight: 600; }
.explainer .ex-title {
display: flex; align-items: center; gap: 8px;
font-size: 0.75rem; font-weight: 700; color: var(–accent);
text-transform: uppercase; letter-spacing: 0.08em;
margin-bottom: 6px;
}

/* ── TOGGLE ROW ───────────────────────────────────────────────────────── */
.toggle-row {
display: flex; align-items: center; justify-content: space-between; gap: 12px;
padding: 12px 14px;
background: var(–surface-1);
border: 1px solid var(–hairline);
border-radius: 12px;
margin-bottom: 8px;
}
.toggle-row .toggle-info { flex: 1; min-width: 0; }
.toggle-row .toggle-info .t { font-weight: 600; font-size: 0.92rem; }
.toggle-row .toggle-info .s { font-size: 0.76rem; color: var(–fg-muted); margin-top: 2px; line-height: 1.4; }
.toggle-switch {
flex-shrink: 0;
width: 46px; height: 28px;
background: var(–surface-3);
border-radius: 100px;
position: relative;
cursor: pointer;
transition: background 0.2s;
border: 1px solid var(–hairline);
}
.toggle-switch::after {
content: ‘’;
position: absolute;
top: 2px; left: 2px;
width: 22px; height: 22px;
background: var(–fg-muted);
border-radius: 50%;
transition: all 0.2s var(–ease-spring);
}
.toggle-switch.on { background: var(–accent); border-color: var(–accent); }
.toggle-switch.on::after { left: 20px; background: hsl(220, 30%, 8%); }

.drink-sub {

function advanceRound(){
  game.roundNum += 1;
  const n = game.players.length;

  if(game.settings.mode === 'rotation'){
    // Rotate: next picker is current guesser, next guesser is next in line
    game.pickerIdx = game.guesserIdx;
    game.guesserIdx = (game.guesserIdx + 1) % n;
    if(game.pickerIdx === game.guesserIdx){
      game.guesserIdx = (game.guesserIdx + 1) % n;
    }
  } else {
    // Battle: rotate picker
    game.pickerIdx = (game.pickerIdx + 1) % n;
    game.battleQueueIdx = 0;
    game.battleResults = [];
  }

  updateHeaderMeta();
  saveState();

  if(game.settings.mode === 'battle') showPassScreen('battle-pick');
  else showPassScreen('pick');
}


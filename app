const drinkMaster = document.getElementById('drink-master-toggle');
const drinkSub = document.getElementById('drink-sub');

function syncDrinkUI(){
  if(!drinkMaster || !drinkSub) return;
  drinkMaster.classList.toggle('on', !!game.settings.drink.enabled);
  drinkSub.classList.toggle('open', !!game.settings.drink.enabled);
  document.querySelectorAll('[data-drink]').forEach(el => {
    const key = el.dataset.drink;
    el.classList.toggle('on', !!game.settings.drink[key]);
  });
  document.querySelectorAll('#seg-dist-threshold .segment-btn').forEach(b => {
    b.classList.toggle('active', parseInt(b.dataset.val) === game.settings.drink.distanceThreshold);
  });
  const row = document.getElementById('dist-threshold-row');
  if(row) row.style.display = game.settings.drink.distancePenalty ? '' : 'none';
  // Last-place toggle: only relevant in battle mode
  // Timer warning visibility
  const timerWarn = document.getElementById('timer-warn');
  if(timerWarn){
    const showWarn = game.settings.drink.enabled && game.settings.timer > 0;
    timerWarn.classList.toggle('hide', !showWarn);
  }
  const lastRow = document.querySelector('[data-drink="lastPlace"]')?.closest('.toggle-row');
  if(lastRow){
    if(game.settings.mode === 'rotation'){
      lastRow.style.opacity = '0.4';
      lastRow.style.pointerEvents = 'none';
      let badge = lastRow.querySelector('.mode-badge');
      if(!badge){

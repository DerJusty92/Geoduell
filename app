function buildResultMap(markersFn){
  if(game._resultMap){ game._resultMap.remove(); game._resultMap = null; }
  game._resultMap = makeMap('rmap', { dragging: true, scrollWheelZoom: true, touchZoom: true, doubleClickZoom: true });
  const tIcon = L.divIcon({ html:'<div class="target-pin"></div>', className:'', iconSize:[22,22], iconAnchor:[11,11] });
  L.marker([game.target.lat, game.target.lng], {icon: tIcon, zIndexOffset: 1000}).addTo(game._resultMap)
